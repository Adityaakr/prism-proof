{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Adityaakr/prism-claude-code/schema/proof-packet.schema.json",
  "title": "Prism Proof Packet",
  "description": "Provider-neutral, machine-readable record of one Prism verification run. Emitted by /prism-verify (and, in reduced form, by plan/build/implement) to .prism/runs/<id>.json. This is the spine every Prism UI renders and every provider adapter produces. It answers the article's six questions: Verified, Evidence, Tests, Assumptions, Risks, Verdict.",
  "type": "object",
  "required": ["schemaVersion", "id", "task", "verdict", "verified", "evidence", "tests", "assumptions", "risks"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0",
      "description": "Proof Packet schema version. Bump on breaking changes so renderers can adapt."
    },
    "id": {
      "type": "string",
      "description": "Stable run id, e.g. an ISO timestamp + short slug. Names the file .prism/runs/<id>.json."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "When the run completed. Stamped by the host, not invented by the model."
    },
    "command": {
      "type": "string",
      "enum": ["verify", "plan", "build", "implement", "feedback"],
      "description": "Which Prism command produced this packet."
    },
    "task": {
      "type": "string",
      "description": "The original task statement being verified — verbatim, not paraphrased."
    },
    "diff": {
      "type": "object",
      "description": "The change under verification.",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": ["staged", "branch", "commit-range", "pr", "worktree"],
          "description": "How the diff was obtained."
        },
        "ref": {
          "type": "string",
          "description": "Concrete ref: branch name, commit range (a..b), or PR number/url."
        },
        "filesChanged": {
          "type": "integer",
          "minimum": 0
        },
        "insertions": { "type": "integer", "minimum": 0 },
        "deletions": { "type": "integer", "minimum": 0 }
      }
    },
    "verdict": {
      "type": "object",
      "description": "Q6 — the decision. This is the proof layer's whole point.",
      "required": ["decision", "rationale"],
      "additionalProperties": false,
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["accept", "human-review", "block"],
          "description": "accept = grounded + tests green + no high risk; human-review = uncertain or medium risk; block = a high-severity risk, a failing test presented as done, or a struck load-bearing claim."
        },
        "rationale": {
          "type": "string",
          "description": "One paragraph: why this decision, tied to the risks/tests/assumptions below."
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      }
    },
    "verified": {
      "type": "object",
      "description": "Q1 — scope. What was actually examined vs. left out. Honesty about out-of-scope is mandatory.",
      "required": ["inScope", "outOfScope"],
      "additionalProperties": false,
      "properties": {
        "inScope": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Concrete things checked (e.g. 'balance-transfer path in ledger.ts', 'auth on the new /pay route')."
        },
        "outOfScope": {
          "type": "array",
          "items": { "type": "string" },
          "description": "What was deliberately NOT verified and why (e.g. 'frontend styling — no behavioural risk')."
        }
      }
    },
    "evidence": {
      "type": "object",
      "description": "Q2 — what was examined. Every code claim must anchor to file:line; every API claim to a doc/type source.",
      "required": ["files"],
      "additionalProperties": false,
      "properties": {
        "files": {
          "type": "array",
          "description": "Exact file:line ranges a verifier re-opened.",
          "items": {
            "type": "object",
            "required": ["path", "lines"],
            "additionalProperties": false,
            "properties": {
              "path": { "type": "string" },
              "lines": { "type": "string", "description": "e.g. '42' or '42-58'." },
              "why": { "type": "string", "description": "What this range establishes." }
            }
          }
        },
        "docs": {
          "type": "array",
          "description": "External API/library docs or installed type defs consulted — checked, never recalled from memory.",
          "items": {
            "type": "object",
            "required": ["source"],
            "additionalProperties": false,
            "properties": {
              "source": { "type": "string", "description": "URL or 'installed types: <pkg>@<version>'." },
              "claim": { "type": "string", "description": "What this source confirms." }
            }
          }
        },
        "rules": {
          "type": "array",
          "description": "Project rules / invariants (from .prism/project-model.md) this change was checked against.",
          "items": {
            "type": "object",
            "required": ["rule"],
            "additionalProperties": false,
            "properties": {
              "rule": { "type": "string" },
              "citation": { "type": "string", "description": "file:line the invariant is anchored to." },
              "status": { "type": "string", "enum": ["upheld", "violated", "n/a"] }
            }
          }
        }
      }
    },
    "tests": {
      "type": "object",
      "description": "Q3 — what passed, failed, or never ran. 'not run' is a first-class outcome, never hidden.",
      "required": ["passed", "failed", "notRun"],
      "additionalProperties": false,
      "properties": {
        "command": { "type": "string", "description": "The actual test command executed." },
        "passed": { "type": "array", "items": { "type": "string" } },
        "failed": { "type": "array", "items": { "type": "string" } },
        "notRun": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tests that exist but were not exercised, and why (e.g. 'e2e — needs a live env')."
        }
      }
    },
    "assumptions": {
      "type": "array",
      "description": "Q4 — unresolved assumptions that could change the verdict if wrong.",
      "items": {
        "type": "object",
        "required": ["claim"],
        "additionalProperties": false,
        "properties": {
          "claim": { "type": "string" },
          "couldChangeVerdict": { "type": "boolean" },
          "howToResolve": { "type": "string" }
        }
      }
    },
    "risks": {
      "type": "array",
      "description": "Q5 — identified issues, each with severity and a location.",
      "items": {
        "type": "object",
        "required": ["severity", "description"],
        "additionalProperties": false,
        "properties": {
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "location": { "type": "string", "description": "file:line where the risk lives." },
          "description": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["security", "data-integrity", "correctness", "ux", "cost", "regression", "supply-chain", "other"]
          }
        }
      }
    },
    "claims": {
      "type": "array",
      "description": "Load-bearing claims and how each survived verification. grounded outranks cross-model-survived.",
      "items": {
        "type": "object",
        "required": ["id", "text", "label"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "label": {
            "type": "string",
            "enum": ["grounded", "cross-model-survived", "cross-tier-survived", "struck"],
            "description": "grounded = re-opened against live code/docs; cross-model-survived = skeptics across DIFFERENT model lineages did not refute (strongest decorrelation); cross-tier-survived = Claude-only tier split (weaker); struck = refuted and removed."
          },
          "citation": { "type": "string" }
        }
      }
    },
    "telemetry": {
      "type": "object",
      "description": "Measured block — the falsifier data. Never prose, never fabricated.",
      "additionalProperties": false,
      "properties": {
        "divergence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "score": { "type": "number", "minimum": 0, "maximum": 1 },
            "evidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "conclusion": { "type": "number", "minimum": 0, "maximum": 1 },
            "threshold": { "type": "number" },
            "calibrated": { "type": "boolean" }
          }
        },
        "grounding": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "precision": { "type": "number", "minimum": 0, "maximum": 1 },
            "recall": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "fleet": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "lenses": { "type": "integer", "minimum": 0 },
            "tokenMultipleVsSingle": { "type": ["number", "null"] }
          }
        },
        "models": {
          "type": "object",
          "description": "The provider-neutral record of which model played which role — the data the dashboard's model-comparison view reads.",
          "additionalProperties": false,
          "properties": {
            "draft": { "type": "string" },
            "judge": { "type": "string" },
            "groundingVerifier": { "type": "string" },
            "skeptics": {
              "type": "array",
              "description": "One entry per skeptic. When lineages differ this is genuine cross-model decorrelation.",
              "items": {
                "type": "object",
                "required": ["model"],
                "additionalProperties": false,
                "properties": {
                  "model": { "type": "string", "description": "e.g. 'claude-opus-4-8', 'gpt-5-codex', 'qwen2.5-coder:32b'." },
                  "provider": { "type": "string", "enum": ["anthropic", "openai", "openai-compatible", "ollama", "other"] },
                  "vote": { "type": "string", "enum": ["refute", "uphold", "abstain"], "description": "Per load-bearing claim votes live in claims[]; this is the run-level summary vote if applicable." }
                }
              }
            },
            "decorrelation": {
              "type": "string",
              "enum": ["cross-model", "cross-tier", "single-model"],
              "description": "cross-model = skeptics span different model lineages (strongest); cross-tier = same lineage, different tiers; single-model = no decorrelation."
            }
          }
        },
        "cost": {
          "type": "object",
          "description": "Per-provider spend for the run — powers the dashboard cost/quality ledger.",
          "additionalProperties": false,
          "properties": {
            "totalUsd": { "type": ["number", "null"] },
            "byProvider": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["provider"],
                "additionalProperties": false,
                "properties": {
                  "provider": { "type": "string" },
                  "tokensIn": { "type": "integer", "minimum": 0 },
                  "tokensOut": { "type": "integer", "minimum": 0 },
                  "usd": { "type": ["number", "null"] }
                }
              }
            }
          }
        }
      }
    }
  }
}
