{
  "name": "@prism/core",
  "version": "0.1.0",
  "description": "Prism Core — the model-agnostic proof-layer engine. Verifies AI-generated diffs across Claude, Codex/GPT and open models, emitting a schema-valid Proof Packet.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "prism": "dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prism": "tsx src/cli.ts",
    "verify": "tsx src/cli.ts verify",
    "dashboard": "tsx src/cli.ts dashboard",
    "mcp": "tsx src/mcp/server.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
